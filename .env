# =============================================
# WhatsApp AI Chatbot System — Environment Config
# Copy this file to .env and fill in the values
# =============================================

# --- n8n Config ---
N8N_HOST=localhost
TIMEZONE=Asia/Jakarta

# --- MySQL Config ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=crm_db
MYSQL_USER=user_crm
MYSQL_PASSWORD=password_crm

# --- OpenAI Config (used inside n8n OpenAI node) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx

# --- WAHA Config ---
WAHA_BASE_URL=http://localhost:3000
WAHA_DASHBOARD_URL=http://localhost:3000
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=admin123
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=admin123
WAHA_API_KEY=df337bd0019f4de7a20bf36798ea47dc

# --- WhatsApp Numbers (for reference) ---
WA_SESSION_1=branch_pusat
WA_SESSION_2=branch_utara
WA_SESSION_3=branch_selatan
WA_SESSION_4=branch_timur

# --- Backend API ---
BACKEND_PORT=4000
AI_PAUSE_MINUTES=15

