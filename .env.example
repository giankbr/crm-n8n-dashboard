# =====================================================================
# WhatsApp AI Chatbot System — Environment Configuration
#
# SETUP: Copy this file to .env and fill in the required values
# $ cp .env.example .env
#
# Then start the system:
# $ docker compose up -d --build
# =====================================================================

# =====================================================================
# SYSTEM & TIMEZONE
# =====================================================================

# System timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Examples: Asia/Jakarta, Asia/Manila, America/New_York, Europe/London
TIMEZONE=Asia/Jakarta

# =====================================================================
# MYSQL DATABASE
# =====================================================================

# MySQL root password (superuser)
# Used for initial setup and migrations
# SECURITY: Change this to a strong password in production
MYSQL_ROOT_PASSWORD=root123

# Database name
# Default is fine unless you want multiple DBs
MYSQL_DATABASE=chatbot_crm

# Non-root database user (backend uses this)
# SECURITY: Change both USER and PASSWORD in production
MYSQL_USER=chatbot_user
MYSQL_PASSWORD=chatbot_pass

# =====================================================================
# BACKEND API SERVER
# =====================================================================

# Backend server port (exposed on http://localhost:4000)
PORT=4000

# MySQL host from backend perspective
# When using Docker: mysql (container name)
# When using localhost: host.docker.internal or 127.0.0.1
MYSQL_HOST=mysql
MYSQL_PORT=3306

# AI pause timeout (minutes)
# How long to pause AI responses when human takes over
# Range: 5–60 minutes (default 15)
AI_PAUSE_MINUTES=15

# Dashboard auth settings (login + RBAC, DB-based)
# DASHBOARD_USERS dipakai untuk seed awal ke tabel admin_users
# Format DASHBOARD_USERS: username:password:role,username2:password2:role2
# Roles: admin, operator
DASHBOARD_AUTH_SECRET=change_me_dashboard_secret
DASHBOARD_AUTH_TTL_HOURS=12
DASHBOARD_USERS=admin:admin123:admin,cs1:cs123:operator

# Node environment
# Values: development, production
NODE_ENV=production

# =====================================================================
# WAHA (WhatsApp HTTP API)
# =====================================================================

# WAHA service base URL
# From Docker: http://waha:3000 (container network)
# From localhost: http://localhost:3000 (or your server IP)
WAHA_BASE_URL=http://waha:3000

# WAHA dashboard URL (for users/frontend)
# Usually points to http://localhost:3000 or your public domain
WAHA_DASHBOARD_URL=http://localhost:3000

# WAHA dashboard authentication
# These are the credentials to access WAHA dashboard at http://localhost:3000
# SECURITY: Change these in production
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=admin123

# WAHA API authentication (optional)
# If WAHA requires API key authentication, set it here
# Otherwise leave empty and it will use username/password above
WAHA_API_KEY=

# Swagger/API credentials (legacy, some WAHA versions use this)
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=admin123

# WAHA session configuration
# Session names for multi-number setup (if using WAHA Plus)
# For WAHA Core (single session), these are for reference only
# The actual session name used is "default"
WA_SESSION_1=branch_pusat
WA_SESSION_2=branch_utara
WA_SESSION_3=branch_selatan
WA_SESSION_4=branch_timur

# WAHA bridge polling interval (milliseconds)
# How often to poll WAHA for new messages
# Range: 1000–10000 (1–10 seconds)
# Smaller = more responsive, higher CPU
# Default 3000 (3 seconds) is balanced
WAHA_POLL_MS=3000

# =====================================================================
# N8N AUTOMATION
# =====================================================================

# n8n server hostname (used for N8N_PROTOCOL and WEBHOOK_URL)
# Examples: localhost, your-domain.com, 192.168.1.100
N8N_HOST=localhost

# n8n port (default 5678, change if port conflict)
N8N_PORT=5678

# n8n execution mode
# Values: regular (default) or queue
N8N_EXECUTION_MODE=regular

# n8n credentials encryption key (advanced)
# Leave empty to auto-generate. Set to 64-char string for reproducible encryption
# N8N_ENCRYPTION_KEY=your-64-character-encryption-key-here

# =====================================================================
# AI INTEGRATION (Optional)
# =====================================================================

# OpenAI API key (used in n8n OpenAI nodes for intent classification)
# Get key from https://platform.openai.com/api-keys
# Format: sk-xxxxxxxxxxxxxxxxxxxx
# Optional: If not set, n8n will skip AI nodes (manual routing only)
OPENAI_API_KEY=

# Google Gemini API key (alternative to OpenAI)
# Get key from https://ai.google.dev/
# Optional, not currently used but reserved for future use
GOOGLE_GEMINI_API_KEY=

# Model selection for AI classification
# Options: gpt-4, gpt-3.5-turbo (OpenAI) or gemini-pro (Google)
AI_MODEL=gpt-3.5-turbo

# =====================================================================
# LOGGING & MONITORING
# =====================================================================

# Log level for backend
# Values: debug, info (default), warn, error
LOG_LEVEL=info

# Enable detailed request logging
# Values: true, false (default)
LOG_REQUESTS=false

# =====================================================================
# OPTIONAL: Google Sheets Integration
# =====================================================================

# Google Sheets API key (for optional sync to Google Sheets)
# Get from Google Cloud Console
# Leave empty if not using Google Sheets
GOOGLE_SHEETS_API_KEY=

# Google Sheets ID (spreadsheet to sync to)
# Format: 1BxiMVs0XRA5nFMKUVfBakKOAydTQT25EFp0_A2MwFM4
# Leave empty if not using Google Sheets
GOOGLE_SHEETS_ID=

# Google Sheets webhook URL (recommended for booking sync from backend)
# Example: https://script.google.com/macros/s/xxxxxxxxxxxxxxxx/exec
# Backend will POST booking payload to this URL when booking is created
GOOGLE_SHEETS_WEBHOOK_URL=

# =====================================================================
# PRODUCTION DEPLOYMENT ONLY
# =====================================================================

# Backend secret key (for future auth implementation)
# Generate: openssl rand -hex 32
BACKEND_SECRET_KEY=

# HTTPS certificate path (if running HTTPS)
# Example: /etc/letsencrypt/live/your-domain.com/fullchain.pem
# Leave empty for HTTP only
SSL_CERT_PATH=

# HTTPS private key path
# Example: /etc/letsencrypt/live/your-domain.com/privkey.pem
# Leave empty for HTTP only
SSL_KEY_PATH=

# =====================================================================
# NOTES
# =====================================================================
#
# 1. Development vs Production:
#    - .env.example: Safe defaults for LOCAL development
#    - Production: Change all passwords, API keys, enable HTTPS
#
# 2. Docker vs Local:
#    - Docker: Use container names (mysql, waha, n8n)
#    - Local: Use localhost or 127.0.0.1
#
# 3. Database Credentials:
#    - First launch: Used for MySQL initialization (root password)
#    - Migrations/Seeding: Used by backend (chatbot_user)
#    - Change both in production!
#
# 4. WAHA Authentication:
#    - API Key: Most secure, use if available
#    - Username/Password: Basic auth as fallback
#    - Leave both empty: No auth (development only)
#
# 5. API Keys:
#    - Never commit .env with real keys to Git
#    - .gitignore already excludes .env
#    - Use .env.example for Git (no secrets)
#
# 6. Support:
#    - Issues: https://github.com/yourusername/ai-agent-crm/issues
#    - Docs: See DATABASE.md, N8N_WORKFLOWS.md, DASHBOARD_SETUP.md
#
